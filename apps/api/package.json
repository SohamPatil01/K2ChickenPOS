{
  "name": "@azela-pos/api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--disable-warning=DEP0169' tsx watch src/index.ts",
    "build": "tsc",
    "start": "NODE_OPTIONS='--disable-warning=DEP0169' node dist/index.js",
    "type-check": "tsc --noEmit",
    "vercel-build": "cd ../.. && pnpm install && pnpm --filter @azela-pos/db generate && pnpm --filter @azela-pos/shared build && pnpm --filter @azela-pos/db build && cd apps/api && node scripts/prepare-vercel.js",
    "postinstall": "cd ../.. && pnpm --filter @azela-pos/db generate"
  },
  "dependencies": {
    "@azela-pos/db": "workspace:*",
    "@azela-pos/shared": "workspace:*",
    "@fastify/cors": "^8.4.0",
    "@fastify/jwt": "^7.2.4",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.7.1",
    "@vercel/blob": "^0.23.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.0",
    "dotenv": "^17.2.3",
    "fastify": "^4.24.3",
    "ioredis": "^5.3.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.0",
    "prisma": "^5.7.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
