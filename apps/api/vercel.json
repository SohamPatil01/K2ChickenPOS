{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile --ignore-scripts=false",
  "buildCommand": "cd ../.. && pnpm install --no-frozen-lockfile && pnpm --filter @azela-pos/db generate && pnpm --filter @azela-pos/shared build && pnpm --filter @azela-pos/db build && cd apps/api && node scripts/prepare-vercel.js",
  "outputDirectory": "",
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }],
  "functions": { "api/index.ts": { "maxDuration": 60 } },
  "crons": [
    { "path": "/api/v1/backup/create", "schedule": "0 15 1 * *" },
    { "path": "/api/v1/backup/storage-cleanup-weekly", "schedule": "0 4 1 * *" },
    { "path": "/api/v1/cron/daily-closing", "schedule": "0 20 * * *" }
  ],
  "headers": [
    {
      "source": "/health",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60, s-maxage=600, stale-while-revalidate=1800" },
        { "key": "CDN-Cache-Control", "value": "public, s-maxage=600, stale-while-revalidate=1800" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=7200" }
      ]
    },
    {
      "source": "/api/v1/products/categories",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=30, s-maxage=120, stale-while-revalidate=300" },
        { "key": "CDN-Cache-Control", "value": "public, s-maxage=300, stale-while-revalidate=600" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=7200" }
      ]
    },
    {
      "source": "/api/v1/backup/health",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60, s-maxage=300, stale-while-revalidate=600" },
        { "key": "CDN-Cache-Control", "value": "public, s-maxage=600, stale-while-revalidate=1200" },
        { "key": "Vercel-CDN-Cache-Control", "value": "public, s-maxage=1800, stale-while-revalidate=3600" }
      ]
    }
  ]
}
