{
  "name": "@azela-pos/db",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "prisma generate --schema=./prisma/schema.prisma && tsc",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma",
    "generate": "prisma generate --schema=./prisma/schema.prisma",
    "migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio --schema=./prisma/schema.prisma",
    "delete-all-sales": "tsx prisma/delete-all-sales.ts",
    "reset-inventory": "tsx prisma/reset-inventory-to-zero.ts",
    "add-product-images": "tsx prisma/add-product-images.ts",
    "fetch-images-from-live": "tsx prisma/fetch-images-from-live.ts"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "prisma": "^5.7.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
