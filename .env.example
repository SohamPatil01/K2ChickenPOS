# Copy to `.env` at repo root (never commit `.env`):
#   cp .env.example .env
# The API loads this file from the monorepo root. Next.js apps also read root `.env` for NEXT_PUBLIC_*.

# --- Database (required for API, Prisma, migrations) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/azela_pos
# Direct Postgres URL for migrations (required). On Neon: non-pooler host. On Supabase: port 5432 session URL.
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/azela_pos

# --- API server ---
# Default in code is 3001. `apps/web` runs on 3000 locally and rewrites `/api` to NEXT_PUBLIC_API_URL.
API_PORT=3001

# --- Auth (required in production; use long random strings) ---
JWT_SECRET=change-me-min-32-chars-for-local-dev-only
# Some deploy docs mention a separate refresh secret; this codebase uses JWT_SECRET for both tokens.
# JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_SECRET=change-me-for-password-reset-tokens

# --- Web / hq-web (browser-exposed; must match your API URL) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
# Optional: HQ console base URL when linking from store web
# NEXT_PUBLIC_HQ_CONSOLE_URL=http://localhost:3002

# --- Customer Display & Dynamic UPI (optional; enables the second-screen display) ---
# Realtime transport for the customer-facing display. Create a free Ably app
# (https://ably.com) and paste its API key here. The cashier browser and the
# TV/tablet connect directly to Ably; our API only mints short-lived tokens, so
# this adds almost no extra Vercel/Neon load. If unset, the display feature is
# simply inert and billing is unaffected.
# ABLY_API_KEY=appId.keyId:secret
# UPI collection details shown as a dynamic QR on the payment screen (browser-exposed):
# NEXT_PUBLIC_UPI_ID=yourshop@okhdfcbank
# NEXT_PUBLIC_UPI_PAYEE=K2 Chicken
# Google review link shown as a QR after payment (browser-exposed; optional):
# NEXT_PUBLIC_REVIEW_URL=https://g.page/r/XXXXXXXXXXXX/review

# --- Optional: Redis / queues ---
# REDIS_URL=redis://localhost:6379

# --- Optional: SMTP (alerts, daily closing emails) ---
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=
# EMAIL_PASSWORD=
# EMAIL_FROM=
# ALERT_EMAIL_RECIPIENTS=
# DAILY_CLOSING_EMAIL_RECIPIENTS=

# --- Optional: scheduled report emails ---
# DEFAULT_REPORT_RECIPIENTS=

# --- Optional: backups (Vercel Blob or S3) ---
# Cron backup is monthly + lean (last BACKUP_TXN_DAYS of sales/ledger) to limit Neon Free 5 GB transfer.
# For a full dump use POST /api/v1/backup/create-full manually — do not put that on a frequent cron.
# BACKUP_SECRET=
# BACKUP_STORAGE_METHOD=vercel-blob
# BACKUP_TXN_DAYS=14
# BLOB_READ_WRITE_TOKEN=
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BACKUP_BUCKET=

# --- Optional: tooling ---
# LIVE_API_URL=              # scripts that hit a live API
# FORCE_SEED=true            # only if you intentionally want seed on prod-like DBs

# --- Shell scripts only (not read by Next/API by default) ---
# Neon / Postgres (production uses Neon — not Supabase)
# DATABASE_URL=
# DIRECT_DATABASE_URL=
# NEON_POOLED_DATABASE_URL=     # optional alias for DATABASE_URL on Neon
# NEON_DATABASE_URL=            # optional alias for DIRECT_DATABASE_URL on Neon
