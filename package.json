{
  "name": "azela-pos",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' --filter './packages/*' dev",
    "dev:hq": "pnpm --filter @azela-pos/hq-web dev",
    "build": "pnpm --recursive build",
    "db:generate": "pnpm --filter @azela-pos/db generate",
    "db:migrate": "pnpm --filter @azela-pos/db migrate",
    "db:migrate:deploy": "pnpm --filter @azela-pos/db migrate:deploy",
    "db:seed": "pnpm --filter @azela-pos/db seed",
    "db:studio": "pnpm --filter @azela-pos/db studio",
    "lint": "pnpm --recursive lint",
    "type-check": "pnpm --recursive type-check"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.27",
      "@types/react-dom": "18.3.7"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@azela-pos/db": "workspace:*",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "tailwind-merge": "^3.4.0"
  }
}
